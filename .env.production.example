# Variables para build de produccion (Capacitor + web)
# Copia este archivo a .env.production cuando vayas a generar el build final.
REACT_APP_API_URL=https://minimarketinnova-production.up.railway.app
REACT_APP_ENV=production
GENERATE_SOURCEMAP=false
APP_URL=https://minimarketinnova-production.up.railway.app

# Firebase Web SDK (Firestore cliente)
REACT_APP_FIREBASE_API_KEY=
REACT_APP_FIREBASE_AUTH_DOMAIN=
REACT_APP_FIREBASE_PROJECT_ID=
REACT_APP_FIREBASE_STORAGE_BUCKET=
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=
REACT_APP_FIREBASE_APP_ID=

# Opcion 1: Resend
RESEND_API_KEY=re_xxxxxxxxx
RESEND_FROM_EMAIL=onboarding@tudominio.com

# Opcion 2: SMTP (ejemplo Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_correo@gmail.com
SMTP_PASS=tu_clave_de_aplicacion
SMTP_FROM=tu_correo@gmail.com
