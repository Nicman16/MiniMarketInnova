# Plantilla de variables de entorno
# No subas secretos reales a este archivo.

# Base de datos
# Local: mongodb://127.0.0.1:27017/minimarket
# Atlas/Railway: mongodb+srv://usuario:contraseña@cluster.mongodb.net/minimarket
MONGO_URI=mongodb://127.0.0.1:27017/minimarket

# JWT
# Usa un valor fuerte en produccion.
JWT_SECRET=tu_clave_secreta_aqui_cambiar_en_produccion

# Puerto del servidor
PORT=3001

# Entorno
NODE_ENV=development

# CORS permitido, separado por comas.
CORS_ORIGIN=http://localhost:3002,http://localhost:3001,capacitor://localhost,ionic://localhost

# URL del backend para web o movil cuando no comparten host.
REACT_APP_API_URL=http://localhost:3001

# URL publica de la app para enlaces de activacion.
APP_URL=http://localhost:3002

# Correo de activacion (opcion 1: Resend)
RESEND_API_KEY=re_xxxxxxxxx
RESEND_FROM_EMAIL=onboarding@tudominio.com

# Correo de activacion (opcion 2: SMTP, por ejemplo Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_correo@gmail.com
SMTP_PASS=tu_clave_de_aplicacion
SMTP_FROM=tu_correo@gmail.com

# Datos demo solo para desarrollo: npm run seed:demo
