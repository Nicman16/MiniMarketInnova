# Plantilla de variables de entorno para MiniMarket Innova
# ⚠️ No subas secretos reales a este archivo.
#
# 🚀 Despliegue en Railway:
#   Configura estas variables en Railway Dashboard > Variables
#   NO uses este archivo .env en Railway (solo para desarrollo local)

# ── FIREBASE (obligatorio) ────────────────────────────────────────
# Opcion A: Pegar el JSON completo del service account
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Opcion B: Base64 del JSON (alternativa, si no quieres pegar el JSON directo)
# FIREBASE_SERVICE_ACCOUNT_BASE64=

# Para desarrollo local: coloca backend/serviceAccountKey.json
# (ya está en .gitignore)

# ── FIREBASE WEB SDK (para el frontend, opcional) ─────────────────
# Solo necesario si usas Firebase desde el cliente
REACT_APP_FIREBASE_API_KEY=
REACT_APP_FIREBASE_AUTH_DOMAIN=
REACT_APP_FIREBASE_PROJECT_ID=minimarket-21bdb
REACT_APP_FIREBASE_STORAGE_BUCKET=
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=
REACT_APP_FIREBASE_APP_ID=

# ── JWT ────────────────────────────────────────────────────────────
JWT_SECRET=tu_clave_secreta_aqui_cambiar_en_produccion

# ── PUERTO ─────────────────────────────────────────────────────────
PORT=3001

# ── ENTORNO ────────────────────────────────────────────────────────
NODE_ENV=development

# ── CORS ───────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3002,http://localhost:3001,capacitor://localhost,ionic://localhost

# ── URL DE LA APP ──────────────────────────────────────────────────
APP_URL=http://localhost:3002

# ── URL DEL BACKEND (para el frontend) ─────────────────────────────
# En Railway con app unificada, NO la definas (frontend usa /api/...)
# Solo si frontend y backend están separados:
REACT_APP_API_URL=http://localhost:3001