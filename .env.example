# Variables de entorno para MiniMarket Innova
# SECURITY: Never commit actual secrets or credentials to this file

# Base de datos MongoDB
# OPCIÓN 1: MongoDB Local (Desarrollo)
#   MONGO_URI=mongodb://127.0.0.1:27017/minimarket
# OPCIÓN 2: MongoDB Atlas (Recomendado para Railway)
#   MONGO_URI=mongodb+srv://usuario:contraseña@cluster.mongodb.net/minimarket
# En Railway: configura en Settings > Environment variables
MONGO_URI=mongodb://127.0.0.1:27017/minimarket

# JWT Secret para autenticación (CAMBIAR EN PRODUCCIÓN)
# Genera uno seguro: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# CRITICAL: Use a strong random value in production, never use default!
JWT_SECRET=tu_clave_secreta_aqui_cambiar_en_produccion

# Puerto del servidor (Railway lo asigna automáticamente)
PORT=3001

# Entorno (development | production)
# IMPORTANT: Set to 'production' in production. Demo users cannot be seeded in production.
NODE_ENV=development

# CORS Configuration
# Restricts API access to specified origins (not wildcard)
# Use comma-separated values when you have web + mobile hybrid clients.
# Example production: https://tu-web.vercel.app,capacitor://localhost,ionic://localhost
CORS_ORIGIN=http://localhost:3002,http://localhost:3001,capacitor://localhost,ionic://localhost

# Frontend API URL (recommended when backend and frontend are not in the same host)
# Web (Vercel): https://tu-api.up.railway.app
# Mobile hybrid (Capacitor): this value is required in production builds
REACT_APP_API_URL=http://localhost:3001

# Demo Data
# To load demo users in development:
#   1. Make sure NODE_ENV=development
#   2. Run: npm run seed:demo
#   3. Use credentials created by the seed script
# WARNING: Demo credentials are for development only
